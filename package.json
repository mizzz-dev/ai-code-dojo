{
  "name": "ai-code-dojo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo foundation for AI-generated code learning platform",
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "test:unit": "node --test $(find tests/unit -name '*.test.mjs' 2>/dev/null | sort)",
    "test:integration": "node --test $(find tests/integration -name '*.test.mjs' 2>/dev/null | sort)",
    "schema:validate": "node scripts/validate-problems.mjs",
    "build": "node scripts/build.mjs",
    "dev:api": "node apps/api/src/server.mjs",
    "dev:worker": "node apps/worker/src/server.mjs",
    "dev:web": "node apps/web/src/server.mjs",
    "test:smoke": "node --test $(find tests/smoke -name '*.test.mjs' 2>/dev/null | sort)",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs"
  },
  "packageManager": "pnpm@10.13.1"
}
