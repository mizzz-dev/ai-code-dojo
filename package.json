{
  "name": "ai-code-dojo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo foundation for AI-generated code learning platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "test:integration": "node --test tests/integration/**/*.test.mjs",
    "schema:validate": "node scripts/validate-problems.mjs",
    "build": "node scripts/build.mjs"
  }
}
