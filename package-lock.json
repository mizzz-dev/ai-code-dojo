{
  "name": "ai-code-dojo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ai-code-dojo",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "node_modules/@ai-dojo/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@ai-dojo/problem-schema": {
      "resolved": "packages/problem-schema",
      "link": true
    },
    "node_modules/@ai-dojo/runner-sdk": {
      "resolved": "packages/runner-sdk",
      "link": true
    },
    "packages/config": {
      "name": "@ai-dojo/config",
      "version": "0.1.0"
    },
    "packages/problem-schema": {
      "name": "@ai-dojo/problem-schema",
      "version": "0.1.0"
    },
    "packages/runner-sdk": {
      "name": "@ai-dojo/runner-sdk",
      "version": "0.1.0"
    }
  }
}
